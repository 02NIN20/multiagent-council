# LLM Provider — pick one:
#   ollama — fully local, no API key needed (default)
#   qwen   — Alibaba Cloud DashScope (requires llm_api_key)
#   openai — OpenAI API (requires llm_api_key)

llm_provider=ollama

# Ollama (local) — no API key needed
llm_model=qwen2.5-coder:7b
llm_base_url=http://localhost:11434/v1
llm_api_key=

# Qwen Cloud (Alibaba) — uncomment and set your key:
# llm_provider=qwen
# llm_api_key=sk-your-key-here
# llm_model=qwen-plus-latest
# llm_base_url=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# OpenAI — uncomment and set your key:
# llm_provider=openai
# llm_api_key=sk-your-key-here
# llm_model=gpt-4o
# llm_base_url=https://api.openai.com/v1

# Embedding model (for semantic memory)
llm_embedding_model=text-embedding-v3
llm_timeout_seconds=300

# Database — only needed if you want persistent sessions
# Default: in-memory (sessions lost on restart)
database_url=
database_echo=false

# Server
host=0.0.0.0
port=8000
cors_origins=["*"]
